#!/usr/bin/env bash

CPU="$(grep -m 1 "vendor_id" /proc/cpuinfo)"
case "$CPU" in
    *GenuineIntel*)
        sed -i 's$__microcode__$sys-firmware/intel-microcode$g' /etc/portage/sets/boot
        ;;
    *AuthenticAMD*)
        sed -i 's$__mircocode$$g'
        ;;
esac


# Replace this file
if  command -v cpuid2cpuflags > /dev/null 2>&1; then
    FLAGS="$(cpuid2cpuflags)"
   cat <<EOF > "$0"
# This file should be autogenerated using app-portage/cpuid2cpuflags
# https://wiki.gentoo.org/wiki/CPU_FLAGS_*#Using_cpuid2cpuflags
*/* $FLAGS

EOF
else
    echo "Please install 'app-portage/cpuid2cpuflags'"
    exit 1
fi


